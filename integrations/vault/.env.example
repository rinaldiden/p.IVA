# Vault configuration — copy to .env and fill in values
# NEVER commit .env to git

# Master secret for credential encryption (generate a strong random string)
VAULT_MASTER_SECRET=CHANGE_ME_generate_a_strong_random_secret_here

# PostgreSQL
VAULT_DB_HOST=localhost
VAULT_DB_PORT=5432
VAULT_DB_NAME=fiscalai_vault
VAULT_DB_USER=vault
VAULT_DB_PASSWORD=CHANGE_ME_strong_password

# Redis
VAULT_REDIS_HOST=localhost
VAULT_REDIS_PORT=6379
VAULT_REDIS_DB=0

# Key derivation iterations (100k recommended, lower for testing)
VAULT_PBKDF2_ITERATIONS=100000

# Days before expiry to trigger warning alerts
VAULT_EXPIRY_WARNING_DAYS=30
