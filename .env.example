# FiscalAI — Environment Variables
# Copia questo file in .env e compila con i tuoi dati

# Anthropic API (per Agent3 Calculator, Agent7 Advisor)
ANTHROPIC_API_KEY=sk-ant-...

# Notifiche
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=

# Open Banking PSD2 (Tink/Yapily)
PSD2_CLIENT_ID=
PSD2_CLIENT_SECRET=
PSD2_IBAN=

# SDI — Sistema di Interscambio
SDI_CODICE_DESTINATARIO=
SDI_ENDPOINT=

# Firma Digitale
FIRMA_PROVIDER=aruba
FIRMA_USERNAME=
FIRMA_PASSWORD=
FIRMA_OTP_SECRET=

# Telegram (notifiche rapide)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
